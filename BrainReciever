#include <esp_now.h>
#include <WiFi.h>
#include <Wire.h>
#include "Adafruit_DRV2605.h"


Adafruit_DRV2605 drv;


// Define a data structure that MATCHES THE TRANSMITTER
typedef struct struct_message {
  // Original fields
  char message[32];      // Status message
  int random_int;        // Random int
  float random_float;    // Random float
  bool random_bool;      // Random bool
 
  // LiDAR sensor data
  int lidar1_distance;   // Distance from sensor 1 in mm
  int lidar2_distance;   // Distance from sensor 2 in mm
  bool lidar1_valid;     // Whether sensor 1 reading is valid
  bool lidar2_valid;     // Whether sensor 2 reading is valid
  unsigned long timestamp; // When the reading was taken
} struct_message;


// Create a structured object
struct_message myData;


// Buzzer control variables
bool buzzerActive = false;
unsigned long lastBuzzTime = 0;
int buzzInterval = 0;  // Will be set based on distance


// Callback function executed when data is received
void OnDataRecv(const uint8_t * mac, const uint8_t *incomingData, int len) {
  memcpy(&myData, incomingData, sizeof(myData));
 
  // Check sensor 1 distance and control buzzer timing
  if (myData.lidar1_valid) {
    if (myData.lidar1_distance >= 1 && myData.lidar1_distance <= 400) {
      if (!buzzerActive) Serial.println("Zone 1 (1-400mm) - Buzzing every 2 seconds");
      buzzInterval = 20;
      buzzerActive = true;
    }
    else if (myData.lidar1_distance > 400 && myData.lidar1_distance <= 800) {
      if (!buzzerActive) Serial.println("Zone 2 (400-800mm) - Buzzing every 4 seconds");
      buzzInterval = 600;
      buzzerActive = true;
    }
    else if (myData.lidar1_distance > 800 && myData.lidar1_distance <= 1200) {
      if (!buzzerActive) Serial.println("Zone 3 (800-1200mm) - Buzzing every 8 seconds");
      buzzInterval = 1000;
      buzzerActive = true;
    }
    else {
      if (buzzerActive) Serial.println("Outside all zones - Stopping buzzer");
      buzzerActive = false;
    }
  } else {
    if (buzzerActive) Serial.println("Invalid reading - Stopping buzzer");
    buzzerActive = false;
  }
 
  // Print basic info
  Serial.print("Data received: ");
  Serial.print(len);
  Serial.println(" bytes");
 
  // Print separator
  Serial.println("=================================");
 
  // Print original data
  Serial.print("Message: ");
  Serial.println(myData.message);
  Serial.print("Random Int: ");
  Serial.println(myData.random_int);
  Serial.print("Random Float: ");
  Serial.println(myData.random_float);
  Serial.print("Random Bool: ");
  Serial.println(myData.random_bool);
 
  // Print LiDAR data
  Serial.println("\n--- LiDAR Readings ---");
 
  // Sensor 1
  Serial.print("Sensor 1: ");
  if (myData.lidar1_valid) {
    Serial.print(myData.lidar1_distance);
    Serial.println(" mm");
  } else {
    Serial.println("Nothing detected");
  }
 
  // Sensor 2
  Serial.print("Sensor 2: ");
  if (myData.lidar2_valid) {
    Serial.print(myData.lidar2_distance);
    Serial.println(" mm");
  } else {
    Serial.println("Nothing detected");
  }
 
  // Print timestamp
  Serial.print("Timestamp: ");
  Serial.println(myData.timestamp);
 
  // Print transmitter MAC address
  Serial.print("From MAC: ");
  for (int i = 0; i < 6; i++) {
    Serial.printf("%02X", mac[i]);
    if (i < 5) Serial.print(":");
  }
  Serial.println();
 
  Serial.println("=================================\n");
}


void playEffect(uint8_t effect, uint8_t repeat) {
  for (uint8_t i = 0; i < repeat; i++) {
    drv.setWaveform(0, effect);
    drv.setWaveform(1, 0);
    drv.go();
    delay(80);  // spacing between clicks (tweak)
  }
}


void setup() {
  // Set up Serial Monitor
  Serial.begin(115200);
  delay(1000);
 
  Serial.println("ESP-NOW LiDAR Receiver with Buzzer Starting...");
 
  // ---- DRV2605 setup
  Wire.begin(21, 22); // SDA, SCL
  if (!drv.begin()) {
    Serial.println("DRV2605 not found on I2C. Check wiring + pullups.");
    while (1) delay(10);
  }


  drv.useLRA();                 // or useERM() depending on your motor
  drv.selectLibrary(1);
  drv.setMode(DRV2605_MODE_INTTRIG);
 
  // Set ESP32 as a Wi-Fi Station
  WiFi.mode(WIFI_STA);
 
  // Display receiver's MAC address (useful for transmitter setup)
  Serial.print("Receiver MAC Address: ");
  Serial.println(WiFi.macAddress());


  // Initialize ESP-NOW
  if (esp_now_init() != ESP_OK) {
    Serial.println("Error initializing ESP-NOW");
    return;
  }
 
  // Register callback function
  esp_now_register_recv_cb(OnDataRecv);
 
  Serial.println("ESP-NOW Ready. Waiting for data...\n");
}
 
void loop() {
  unsigned long currentMillis = millis();
 
  // Run the buzzer pattern at the appropriate interval if active
  if (buzzerActive && (currentMillis - lastBuzzTime >= buzzInterval)) {
    lastBuzzTime = currentMillis;
    playEffect(1, 3);  // effect 1 (strong click), repeated 3 times
  }
 
  delay(10);  // Small delay to prevent CPU hogging
}

