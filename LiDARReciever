#include <esp_now.h>
#include <WiFi.h>

typedef struct __attribute__((packed)) {
  uint16_t distance_mm;
  uint8_t  rangeStatus;
  uint8_t  dataReady;
  uint32_t seq;
} lidar_packet_t;

lidar_packet_t pkt;

void OnDataRecv(const uint8_t *mac, const uint8_t *incomingData, int len) {
  if (len != sizeof(pkt)) {
    Serial.print("Bad packet size: ");
    Serial.println(len);
    return;
  }

  memcpy(&pkt, incomingData, sizeof(pkt));

  Serial.print("RX seq=");
  Serial.print(pkt.seq);
  Serial.print(" | status=");
  Serial.print(pkt.rangeStatus);
  Serial.print(" | distance_mm=");

  // Your “valid only” logic:
  if (pkt.rangeStatus == 0 && pkt.distance_mm <= 2000) {
    Serial.println(pkt.distance_mm);
  } else {
    Serial.println("Nothing detected");
  }
}

void setup() {
  Serial.begin(115200);
  delay(500);

  WiFi.mode(WIFI_STA);
  Serial.print("RX MAC: ");
  Serial.println(WiFi.macAddress());

  if (esp_now_init() != ESP_OK) {
    Serial.println("Error initializing ESP-NOW");
    while (true) {}
  }

  esp_now_register_recv_cb(OnDataRecv);
  Serial.println("ESP-NOW receiver ready.");
}

void loop() {
  // Nothing needed; callback prints received data
}
